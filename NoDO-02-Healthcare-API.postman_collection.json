{
  "info": {
    "name": "NoDO-02 Healthcare API",
    "description": "Postman collection for Dockerized Healthcare Flask API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Get All Patients",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/patients/",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", ""]
        }
      }
    },
    {
      "name": "Create Patient",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Priya Singh\",\n  \"age\": 28,\n  \"gender\": \"Female\",\n  \"contact\": \"9000000001\",\n  \"blood_group\": \"B+\",\n  \"diagnosis\": \"Diabetes Type 2\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/patients/",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", ""]
        }
      }
    },
    {
      "name": "Get Patient by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/patients/1",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "1"]
        }
      }
    },
    {
      "name": "Update Patient",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"diagnosis\": \"Diabetes Type 2 - Controlled\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/patients/1",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "1"]
        }
      }
    },
    {
      "name": "Delete Patient",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/patients/1",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "1"]
        }
      }
    },
    {
      "name": "Create Patient - Missing Fields (400 test)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Incomplete Patient\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/patients/",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", ""]
        }
      }
    },
    {
      "name": "Get Patient - Not Found (404 test)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/patients/999",
          "host": ["{{base_url}}"],
          "path": ["api", "patients", "999"]
        }
      }
    }
  ]
}
